+/*
+ * vm_normal_page_seam - decode encoded PTE, clean up usecount, then delegate
+ * to vm_normal_page() for standard validation.
+ *
+ * @out_pte: if non-NULL, the decoded PTE is written back (unmap path).
+ *           Also controls whether non-encoded CXL pages get usecount cleanup.
+ *           Pass NULL for the COW/readonly path.
+ */
+static struct page *vm_normal_page_seam(struct vm_area_struct *vma,
+					unsigned long addr, pte_t pte,
+					volatile pte_t *out_pte)
+{
+    unsigned long pfn = pte_pfn(pte);
+
+    /* Always decode if encode bit is set, regardless of seam_encode_enabled,
+     * so that cleanup/unmap operations work after encoding is disabled. */
+    if ((pte_val(pte) & _PAGE_ENCODE_BIT) && pfn >= end_cxl_pfn) {
+        unsigned long encoded_pfn = pfn;
+        int decoded_encode_idx = (encoded_pfn - end_cxl_pfn) % lmm_group_size;
+        unsigned long orig_pfn = (encoded_pfn - end_cxl_pfn - decoded_encode_idx) / lmm_group_size + base_pfn;
+        if (orig_pfn >= base_pfn && orig_pfn < end_cxl_pfn) {
+            pfn = orig_pfn;
+            struct page *page = pfn_to_page(pfn);
+            if (PageKsm(page))
+                atomic_dec(&num_ksm_coded);
+            else
+                atomic_dec(&num_file_coded);
+            unsigned long mask = ~(PFN_MASK | _PAGE_ENCODE_BIT);
+            unsigned long old_val = pte_val(pte);
+            unsigned long new_val = (old_val & mask) | (pfn << PAGE_SHIFT);
+            pte = __pte(new_val);
+            if (out_pte)
+                *out_pte = pte;
+            u64 cgroup_id = get_task_cgroup_id(current);
+            reset_page_usecount_v2(page, cgroup_id, pfn);
+        }
+    } else if (out_pte && pfn >= base_pfn && pfn < end_cxl_pfn) {
+        /* Non-encoded CXL page - usecount cleanup only on unmap path */
+        struct page *page = pfn_to_page(pfn);
+        if (page->page_cgroup_vector) {
+            u64 cgroup_id = get_task_cgroup_id(current);
+            reset_page_usecount_v2(page, cgroup_id, pfn);
+        }
+    }
+
+    return vm_normal_page(vma, addr, pte);
+}
