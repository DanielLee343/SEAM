+static u8 find_random_available_bit(u8 intermediate_bitvector)
+{
+	u8 available_count = 0;
+	u8 available_indices[8];
+	int i;
+
+	for (i = 0; i < 8; i++) {
+		if (!(intermediate_bitvector & (1 << i))) {
+			available_indices[available_count++] = i;
+		}
+	}
+
+	if (available_count == 0)
+		return 255; /* No available bits */
+
+	get_random_bytes(&i, sizeof(i));
+	return available_indices[((unsigned int)i) % available_count];
+}
