+int init_page_cgroup_vector_v2(struct page_cgroup_vector **vec)
+{
+	*vec = kzalloc(sizeof(struct page_cgroup_vector), GFP_KERNEL);
+	if (!*vec) {
+		pr_err("Failed to allocate page_cgroup_vector\n");
+		return -ENOMEM;
+	}
+
+	(*vec)->data = kzalloc(sizeof(struct page_cgroup_triplet) * INITIAL_VECTOR_CAPACITY, GFP_KERNEL);
+	if (!(*vec)->data) {
+		pr_err("Failed to allocate page_cgroup_vector data\n");
+		kfree(*vec);
+		*vec = NULL;
+		return -ENOMEM;
+	}
+
+	spin_lock_init(&(*vec)->lock);
+	(*vec)->capacity = INITIAL_VECTOR_CAPACITY;
+	(*vec)->size = 0;
+	return 0;
