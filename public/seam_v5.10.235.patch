+	/* Resize vector if needed */
+	if (vec->size >= vec->capacity) {
+		int new_capacity = vec->capacity + (vec->capacity / 2);
+		// pr_info("resizing to %d\n", new_capacity);
+		if (resize_vector(vec, new_capacity) != 0) {
+			*encode_idx = -1;
+			spin_unlock(&vec->lock);
+			return non_zero_count;
+		}
+	}
+
+	/* Add new triplet */
+	vec->data[vec->size].cgroup_id = cgroup_id_16;
+	vec->data[vec->size].encode_idx = new_encode_idx;
+	vec->data[vec->size].map_count = 1;
+	vec->size++;
+
+	*encode_idx = new_encode_idx;
+	non_zero_count++;
+
+	spin_unlock(&vec->lock);
+	return non_zero_count;
+}
+
+/* RCU callback to free page_cgroup_vector asynchronously */
+static void free_page_cgroup_vector_rcu(struct rcu_head *head)
+{
+	struct page_cgroup_vector *vec;
+
+	vec = container_of(head, struct page_cgroup_vector, rcu);
+	kfree(vec->data);
+	kfree(vec);
+}
+
+int reset_page_usecount_v2(struct page *page, u64 curr_cgroup_id,
+			   unsigned long pfn)
+{
+	struct page_cgroup_vector *vec;
+
+	if (!curr_cgroup_id) {
+		return 0;
+	}
+
+	/* RCU read-side critical section prevents vector from being freed */
+	rcu_read_lock();
+
+	vec = rcu_dereference(page->page_cgroup_vector);
+	if (!vec) {
+		rcu_read_unlock();
+		return 0;
+	}
+
+	/* Lock the vector itself, not the page table lock */
+	spin_lock(&vec->lock);
+
+	/* Can unlock RCU now that we hold the spinlock */
+	rcu_read_unlock();
+
+	u16 cgroup_id_16 = (u16)(curr_cgroup_id & 0xFFFF);
+	int found_idx = -1;
+	int non_zero_count = 0;
+	int i;
+
+	for (i = 0; i < vec->size; i++) {
+		if (vec->data[i].cgroup_id == cgroup_id_16) {
+			found_idx = i;
+			if (vec->data[i].map_count > 0) {
+				vec->data[i].map_count--;
+			}
+			if (vec->data[i].map_count == 0) {
+				/* Remove entry when map_count drops to 0 */
+				memmove(&vec->data[i], &vec->data[i + 1],
+					sizeof(struct page_cgroup_triplet) * (vec->size - i - 1));
+				vec->size--;
+				i--; /* Adjust index after removal */
+			}
+		}
+	}
+
+	/* Count non-zero entries after all modifications */
+	for (i = 0; i < vec->size; i++) {
+		if (vec->data[i].cgroup_id != 0) {
+			non_zero_count++;
+		}
+	}
+
+	/* Shrink vector if usage is low */
+	if (vec->size > 0 && vec->size < vec->capacity / SHRINK_THRESHOLD_RATIO &&
+	    vec->capacity > INITIAL_VECTOR_CAPACITY) {
+		int new_capacity = max(INITIAL_VECTOR_CAPACITY, vec->capacity / 2);
+		resize_vector(vec, new_capacity);
+	}
+
+	/* Free vector if empty */
+	if (vec->size == 0) {
+		/* Clear pointer while still holding lock to prevent new readers */
+		rcu_assign_pointer(page->page_cgroup_vector, NULL);
+
+		spin_unlock(&vec->lock);
+
+		/* Schedule asynchronous freeing after RCU grace period
+		 * This does NOT block - freeing happens later via callback */
+		call_rcu(&vec->rcu, free_page_cgroup_vector_rcu);
+		return 0;
+	}
+
+	spin_unlock(&vec->lock);
+	return non_zero_count;
+}
+
+void free_page_cgroup_vector_v2(void)
+{
+	unsigned long start_pfn = base_pfn;
+	unsigned long curr_pfn;
+	for (curr_pfn = start_pfn; curr_pfn < end_cxl_pfn; curr_pfn++) {
+		if (!pfn_valid(curr_pfn)) {
+			continue;
+		}
+		struct page *page = pfn_to_page(curr_pfn);
+		if (page->page_cgroup_vector) {
+			kfree(page->page_cgroup_vector->data);
+			kfree(page->page_cgroup_vector);
+			page->page_cgroup_vector = NULL;
+		}
+	}
+}
+
+void print_unfreed_cgroup_vector(void)
+{
+	unsigned long start_pfn = base_pfn;
+	unsigned long curr_pfn;
+	int i;
+	int nid;
+	struct page *page;
+	struct page_cgroup_vector *vec;
+
+	for (curr_pfn = start_pfn; curr_pfn < end_cxl_pfn; curr_pfn++) {
+		nid = pfn_to_nid(curr_pfn);
+		if (!pfn_valid(curr_pfn) || !node_online(nid) ||
+		    !valid_section(__pfn_to_section(curr_pfn))) {
+			pr_info("non_valid pfn: %lu\n", curr_pfn);
+			continue;
+		}
+		page = pfn_to_page(curr_pfn);
+		if (page->page_cgroup_vector) {
+			vec = page->page_cgroup_vector;
+			pr_info("----------");
+			pr_info("%lu\n", curr_pfn);
+			for (i = 0; i < vec->size; i++) {
+				pr_info("<%u,%u,%u> ",
+					vec->data[i].cgroup_id,
+					vec->data[i].encode_idx,
+					vec->data[i].map_count);
+			}
+		}
+	}
+}
