+#ifndef _ENCODE_COMMON_H
+#define _ENCODE_COMMON_H
+
+#include <linux/types.h>
+#include <linux/atomic.h>
+#include <linux/bits.h>
+
+/* PTE encoding bit definitions */
+#define PFN_MASK GENMASK_ULL(51, 12)
+#define _PAGE_ENCODE_BIT (1UL << 52)
+
+struct page_cgroup_tuple {
+	u64 cgroup_id;
+	int map_count;
+};
+
+struct page_cgroup_triplet {
+	u16 cgroup_id;    /* 2 bytes - truncated from u64 */
+	u8 encode_idx;    /* 1 byte */
+	u8 map_count;     /* 1 byte */
+} __packed;           /* Total: 4 bytes */
+
+struct page_cgroup_vector {
+	struct page_cgroup_triplet *data;
+	int capacity;
+	int size;
+	spinlock_t lock;  /* Protects data, capacity, and size */
+	struct rcu_head rcu;  /* For RCU-safe asynchronous freeing */
+};
+extern unsigned long base_pfn;
+extern unsigned long num_cxl_page_entries;
+extern unsigned long lmm_group_size; /* Number of encoding slots; max different cgroups per page = lmm_group_size - 1. Max supported: 64 */
+extern unsigned long end_cxl_pfn;
+
+/* ioremap'd cached mapping for encoded PFN range (for clflush) */
+extern void __iomem *encoded_range_base;
+extern unsigned long encoded_range_phys_start;
+
+/* Encoding control variables */
+extern atomic_t seam_encode_enabled;
+extern atomic_t num_file_coded;  /* Counter for file-backed page encoding (alloc_set_pte) */
+extern atomic_t num_ksm_coded;   /* Counter for KSM anonymous page encoding (replace_page) */
+
+/* Diagnostic counters */
+extern atomic_t num_ksm_skipped;    /* KSM merged but SEAM encoding skipped (lock contention or alloc failure) */
+
+/* Helper functions */
+struct task_struct;
+struct vm_area_struct;
+u64 get_task_cgroup_id(struct task_struct *task);
+struct page *vm_normal_page_seam(struct vm_area_struct *vma, unsigned long addr,
+				 pte_t pte, volatile pte_t *out_pte);
+pte_t seam_encode_pte(pte_t orig_pte, int encode_idx, unsigned long *new_pfn);
+void seam_flush_page_with_clwb(void *page_addr);
+
+/* Decode an encoded PFN back to its real PFN.  Returns @pfn unchanged for
+ * non-encoded PTEs.  Always valid to call whether SEAM is enabled or not, so
+ * cleanup paths work after encoding is disabled. */
+static inline unsigned long seam_decode_pfn_raw(unsigned long pte_val_, unsigned long pfn)
+{
+	if ((pte_val_ & _PAGE_ENCODE_BIT) && pfn >= end_cxl_pfn) {
+		unsigned long idx = (pfn - end_cxl_pfn) % lmm_group_size;
+		unsigned long decoded = (pfn - end_cxl_pfn - idx) / lmm_group_size + base_pfn;
+
+		if (decoded >= base_pfn && decoded < end_cxl_pfn)
+			return decoded;
+	}
+	return pfn;
+}
+#define seam_decode_pfn(pte) seam_decode_pfn_raw(pte_val(pte), pte_pfn(pte))
+
+#endif
