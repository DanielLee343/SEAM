+		return -ENOMEM;
+
+	(*vec)->data = kzalloc_node(sizeof(struct page_cgroup_triplet) * INITIAL_VECTOR_CAPACITY, gfp, node);
+	if (!(*vec)->data) {
+		kfree(*vec);
+		*vec = NULL;
+		return -ENOMEM;
+	}
+
+	spin_lock_init(&(*vec)->lock);
+	(*vec)->capacity = INITIAL_VECTOR_CAPACITY;
+	(*vec)->size = 0;
+	return 0;
+}
+
+/* GFP_ATOMIC on local node — for callers under PTL (alloc_set_pte) */
+int init_page_cgroup_vector_v2(struct page_cgroup_vector **vec)
+{
+	return init_page_cgroup_vector_v2_node(vec, GFP_ATOMIC, NUMA_NO_NODE);
+}
+
+static int resize_vector(struct page_cgroup_vector *vec, int new_capacity)
+{
+	struct page_cgroup_triplet *new_data;
+
+	/* CRITICAL: Use GFP_ATOMIC since this can be called while holding spinlock */
+	new_data = kzalloc(sizeof(struct page_cgroup_triplet) * new_capacity, GFP_ATOMIC);
+	if (!new_data) {
+		pr_err("Failed to resize page_cgroup_vector\n");
+		return -ENOMEM;
+	}
+
+	if (vec->data) {
+		memcpy(new_data, vec->data, sizeof(struct page_cgroup_triplet) * vec->size);
+		kfree(vec->data);
+	}
+
+	vec->data = new_data;
+	vec->capacity = new_capacity;
+	return 0;
+}
+
+static u8 find_random_available_bit(u64 intermediate_bitvector)
+{
+	u8 available_count = 0;
+	u8 available_indices[64];  /* Support up to 64 encoding slots */
+	int i;
+
+	/* Check all lmm_group_size slots (ioremap covers full stride) */
+	for (i = 0; i < lmm_group_size; i++) {
+		if (!(intermediate_bitvector & (1ULL << i))) {
+			available_indices[available_count++] = i;
+		}
+	}
+
+	if (available_count == 0)
+		return 255; /* No available bits */
+
+	return available_indices[prandom_u32() % available_count];
+}
+
+int try_inc_page_usecount_v2(struct page *page, unsigned long old_pfn,
+			     u64 curr_cgroup_id, int *encode_idx)
+{
+	struct page_cgroup_vector *vec;
+
+	if (old_pfn < base_pfn || old_pfn >= base_pfn + num_cxl_page_entries || !page) {
+		return 0;
+	}
+
+	/* RCU read-side critical section prevents vector from being freed */
+	rcu_read_lock();
+
+	vec = rcu_dereference(page->page_cgroup_vector);
+	if (!vec) {
+		rcu_read_unlock();
+		return 0;
+	}
+
+	spin_lock(&vec->lock);
+
+	/* Can unlock RCU now that we hold the spinlock */
+	rcu_read_unlock();
+
+	u16 cgroup_id_16 = (u16)(curr_cgroup_id & 0xFFFF);
+	int found_idx = -1;
+	int non_zero_count = 0;
+	u64 intermediate_bitvector = 0;  /* Up to 64-bit bitvector for lmm_group_size */
+	int i;
+
+	/* Linear scan: check for matching cgroup_id and populate intermediate bitvector */
+	for (i = 0; i < vec->size; i++) {
+		if (vec->data[i].cgroup_id == cgroup_id_16) {
+			found_idx = i;
+		}
+		if (vec->data[i].cgroup_id != 0) {
+			non_zero_count++;
+			/* Set bit in intermediate bitvector based on encode_idx */
+			/* Ensure encode_idx is within valid range (0 to lmm_group_size-1) */
+			if (vec->data[i].encode_idx < lmm_group_size) {
+				intermediate_bitvector |= (1ULL << vec->data[i].encode_idx);
+			}
+		}
+	}
+
+	/* If found matching cgroup_id, increment map_count and return immediately.
+	 * Return the existing encode_idx so the caller can re-encode the PTE
+	 * (needed for KSM re-merges after COW breaks). */
+	if (found_idx != -1) {
+		*encode_idx = vec->data[found_idx].encode_idx;
+		vec->data[found_idx].map_count++;
+		spin_unlock(&vec->lock);
+		return non_zero_count;
+	}
+
+	/* No matching cgroup_id found - need to create new entry */
+	/* Check if we've reached the maximum capacity (lmm_group_size) */
+	if (non_zero_count >= lmm_group_size) {
+		*encode_idx = -1;  /* Maximum cgroups per page reached */
+		spin_unlock(&vec->lock);
+		return non_zero_count;
+	}
+
+	/* Use intermediate bitvector to randomly choose available encode_idx */
+	u8 new_encode_idx = find_random_available_bit(intermediate_bitvector);
+	if (new_encode_idx == 255) {
+		*encode_idx = -1;  /* No available encoding slots */
+		spin_unlock(&vec->lock);
+		return non_zero_count;
+	}
+
+	/* Resize vector if needed */
+	if (vec->size >= vec->capacity) {
+		int new_capacity = vec->capacity + (vec->capacity / 2);
+		if (resize_vector(vec, new_capacity) != 0) {
+			*encode_idx = -1;
+			spin_unlock(&vec->lock);
+			return non_zero_count;
+		}
+	}
+
+	/* Add new triplet */
+	vec->data[vec->size].cgroup_id = cgroup_id_16;
+	vec->data[vec->size].encode_idx = new_encode_idx;
+	vec->data[vec->size].map_count = 1;
+	vec->size++;
+
+	*encode_idx = new_encode_idx;
+	non_zero_count++;
+
+	spin_unlock(&vec->lock);
+	return non_zero_count;
+}
+
+/* RCU callback to free page_cgroup_vector asynchronously */
+static void free_page_cgroup_vector_rcu(struct rcu_head *head)
+{
+	struct page_cgroup_vector *vec;
+
+	vec = container_of(head, struct page_cgroup_vector, rcu);
+	kfree(vec->data);
+	kfree(vec);
+}
+
+int reset_page_usecount_v2(struct page *page, u64 curr_cgroup_id,
+			   unsigned long pfn)
+{
+	struct page_cgroup_vector *vec;
+
+	if (!curr_cgroup_id) {
+		return 0;
+	}
+
+	/* RCU read-side critical section prevents vector from being freed */
+	rcu_read_lock();
+
+	vec = rcu_dereference(page->page_cgroup_vector);
+	if (!vec) {
+		rcu_read_unlock();
+		return 0;
+	}
+
+	/* Lock the vector itself, not the page table lock */
+	spin_lock(&vec->lock);
+
+	/* Can unlock RCU now that we hold the spinlock */
+	rcu_read_unlock();
+
+	u16 cgroup_id_16 = (u16)(curr_cgroup_id & 0xFFFF);
+	int found_idx = -1;
+	int non_zero_count = 0;
+	int i;
+
+	for (i = 0; i < vec->size; i++) {
+		if (vec->data[i].cgroup_id == cgroup_id_16) {
+			found_idx = i;
+			if (vec->data[i].map_count > 0) {
+				vec->data[i].map_count--;
+			}
+			if (vec->data[i].map_count == 0) {
+				/* Remove entry when map_count drops to 0 */
+				memmove(&vec->data[i], &vec->data[i + 1],
+					sizeof(struct page_cgroup_triplet) * (vec->size - i - 1));
+				vec->size--;
+				i--; /* Adjust index after removal */
+			}
+		}
+	}
+
+	/* Count non-zero entries after all modifications */
+	for (i = 0; i < vec->size; i++) {
+		if (vec->data[i].cgroup_id != 0) {
+			non_zero_count++;
+		}
+	}
+
+	/* Shrink vector if usage is low */
+	if (vec->size > 0 && vec->size < vec->capacity / SHRINK_THRESHOLD_RATIO &&
+	    vec->capacity > INITIAL_VECTOR_CAPACITY) {
+		int new_capacity = max(INITIAL_VECTOR_CAPACITY, vec->capacity / 2);
+		resize_vector(vec, new_capacity);
+	}
+
+	/* Free vector if empty */
+	if (vec->size == 0) {
+		/* Only call_rcu if WE are the one to NULL the pointer.
+		 * free_page_cgroup_vector_v2 may have already NULLed it and
+		 * scheduled its own call_rcu — double call_rcu corrupts the
+		 * RCU callback chain. */
+		if (rcu_access_pointer(page->page_cgroup_vector) == vec) {
+			rcu_assign_pointer(page->page_cgroup_vector, NULL);
+			spin_unlock(&vec->lock);
+			call_rcu(&vec->rcu, free_page_cgroup_vector_rcu);
+		} else {
+			spin_unlock(&vec->lock);
+		}
+		return 0;
+	}
+
+	spin_unlock(&vec->lock);
+	return non_zero_count;
+}
+
+void free_page_cgroup_vector_v2(void)
+{
+	unsigned long curr_pfn;
+	struct page *page;
+	struct page_cgroup_vector *vec;
+
+	for (curr_pfn = base_pfn; curr_pfn < end_cxl_pfn; curr_pfn++) {
+		if (!pfn_valid(curr_pfn))
+			continue;
+		page = pfn_to_page(curr_pfn);
+
+		/* Use RCU + spinlock to safely race with reset_page_usecount_v2.
+		 * rcu_read_lock prevents the vec from being freed between our
+		 * pointer read and spinlock acquisition.  The spinlock serializes
+		 * with reset_page_usecount_v2.  Only the "winner" (whoever NULLs
+		 * the pointer) calls call_rcu — preventing double-enqueue. */
+		rcu_read_lock();
+		vec = rcu_dereference(page->page_cgroup_vector);
+		if (vec) {
+			spin_lock(&vec->lock);
+			rcu_read_unlock();
+			if (rcu_access_pointer(page->page_cgroup_vector) == vec) {
+				rcu_assign_pointer(page->page_cgroup_vector, NULL);
+				spin_unlock(&vec->lock);
+				call_rcu(&vec->rcu, free_page_cgroup_vector_rcu);
+			} else {
+				/* reset_page_usecount_v2 already NULLed it */
+				spin_unlock(&vec->lock);
+			}
+		} else {
+			rcu_read_unlock();
+		}
+	}
+
+	/* Wait for all call_rcu callbacks (ours + reset_page_usecount_v2's)
+	 * to complete before returning, so the caller knows all vectors
+	 * are fully freed. */
+	rcu_barrier();
+}
+
+void print_unfreed_cgroup_vector(void)
+{
+	unsigned long start_pfn = base_pfn;
+	unsigned long curr_pfn;
+	int i;
+	int nid;
+	struct page *page;
+	struct page_cgroup_vector *vec;
+
+	for (curr_pfn = start_pfn; curr_pfn < end_cxl_pfn; curr_pfn++) {
+		nid = pfn_to_nid(curr_pfn);
+		if (!pfn_valid(curr_pfn) || !node_online(nid) ||
+		    !valid_section(__pfn_to_section(curr_pfn))) {
+			pr_info("non_valid pfn: %lu\n", curr_pfn);
+			continue;
+		}
+		page = pfn_to_page(curr_pfn);
+		if (page->page_cgroup_vector) {
+			vec = page->page_cgroup_vector;
+			pr_info("----------");
+			pr_info("%lu\n", curr_pfn);
+			for (i = 0; i < vec->size; i++) {
+				pr_info("<%u,%u,%u> ",
+					vec->data[i].cgroup_id,
+					vec->data[i].encode_idx,
+					vec->data[i].map_count);
+			}
+		}
+	}
+}
+
+/* ---- debugfs control plane: /sys/kernel/debug/seam_debug/ ---- */
+
+static ssize_t seam_encode_write(struct file *file, const char __user *buf,
+				 size_t count, loff_t *ppos)
+{
+	int tmp;
+
+	if (kstrtoint_from_user(buf, count, 0, &tmp))
+		return -EINVAL;
+	if (tmp != 0 && tmp != 1) {
+		pr_info("unsupported value: %d\n", tmp);
+		return -EINVAL;
+	}
+
+	if (tmp == 1) {
+		/* Create a cached ioremap for the encoded PFN range so clflush
+		 * works even when the direct map doesn't cover it.  Total span =
+		 * num_cxl_page_entries * lmm_group_size pages.  lmm_group_size
+		 * MUST match the FPGA's decode group size. */
+		unsigned long total_encoded_pages = num_cxl_page_entries * lmm_group_size;
+		unsigned long mapping_size = total_encoded_pages << PAGE_SHIFT;
+
+		encoded_range_phys_start = end_cxl_pfn << PAGE_SHIFT;
+		encoded_range_base = ioremap_cache(encoded_range_phys_start, mapping_size);
+		if (encoded_range_base)
+			pr_info("seam: ioremap_cache 0x%lx size %lu MB at %px\n",
+				encoded_range_phys_start, mapping_size >> 20, encoded_range_base);
+		else
+			pr_warn("seam: failed to ioremap_cache encoded range\n");
+	} else if (encoded_range_base) {
+		/* NULL the pointer first so new users see NULL and skip clflush,
+		 * then synchronize_rcu to wait for any in-flight clflush (under
+		 * rcu_read_lock) before unmapping. */
+		void __iomem *old_base = encoded_range_base;
+
+		WRITE_ONCE(encoded_range_base, NULL);
+		synchronize_rcu();
+		iounmap(old_base);
+		pr_info("seam: iounmap encoded range at %px\n", old_base);
+	}
+
+	atomic_set(&seam_encode_enabled, tmp);
+	pr_info("resetting all cgroup_vector (encode=%d)\n", tmp);
+	free_page_cgroup_vector_v2();
+	atomic_set(&num_file_coded, 0);
+	atomic_set(&num_ksm_coded, 0);
+	atomic_set(&num_ksm_skipped, 0);
+	return count;
+}
+
+static ssize_t seam_encode_read(struct file *file, char __user *buf,
+				size_t count, loff_t *ppos)
+{
+	char val_buf[16];
+	int len = scnprintf(val_buf, sizeof(val_buf), "%d\n",
+			    atomic_read(&seam_encode_enabled));
+	return simple_read_from_buffer(buf, count, ppos, val_buf, len);
+}
+
+static const struct file_operations seam_encode_fops = {
+	.owner = THIS_MODULE,
+	.read  = seam_encode_read,
+	.write = seam_encode_write,
+};
+
+static ssize_t seam_peek_write(struct file *file, const char __user *buf,
+			       size_t count, loff_t *ppos)
+{
+	int tmp;
+
+	if (kstrtoint_from_user(buf, count, 0, &tmp))
+		return -EINVAL;
+	if (tmp == 0) {
+		pr_info("unfreed cgroup_vector\n");
+		print_unfreed_cgroup_vector();
+	} else if (tmp == 1) {
+		pr_info("num_file_coded: %d, num_ksm_coded: %d, num_ksm_skipped: %d\n",
+			atomic_read(&num_file_coded), atomic_read(&num_ksm_coded),
+			atomic_read(&num_ksm_skipped));
+	} else {
+		return -EINVAL;
+	}
+	return count;
+}
+
+static const struct file_operations seam_peek_fops = {
+	.owner = THIS_MODULE,
+	.write = seam_peek_write,
+};
+
+static int __init init_seam_debugfs(void)
+{
+	struct dentry *dir = debugfs_create_dir("seam_debug", NULL);
+
+	if (IS_ERR_OR_NULL(dir))
+		return 0;
+	debugfs_create_file("encode_enable", 0644, dir, NULL, &seam_encode_fops);
+	debugfs_create_file("peek_stats",    0200, dir, NULL, &seam_peek_fops);
+	return 0;
+}
+late_initcall(init_seam_debugfs);
+
+/* ---- SEAM helpers used by memory.c / ksm.c ---- */
+
+u64 get_task_cgroup_id(struct task_struct *task)
+{
+	struct cgroup *cgrp;
+	u64 id = 0;
+
+	if (!task) {
+		pr_err("task is NULL!!\n");
+		return 0;
+	}
+
+	rcu_read_lock();
+	cgrp = task_dfl_cgroup(task);
+	if (cgrp && cgrp->kn)
+		id = cgrp->kn->id;
+	rcu_read_unlock();
+	return id;
+}
+
+pte_t seam_encode_pte(pte_t orig_pte, int encode_idx, unsigned long *new_pfn)
+{
+	unsigned long old_val = pte_val(orig_pte);
+	unsigned long old_pfn = (old_val & PFN_MASK) >> PAGE_SHIFT;
+	unsigned long enc_pfn = (old_pfn - base_pfn) * lmm_group_size + end_cxl_pfn + encode_idx;
+	unsigned long new_val = (old_val & ~PFN_MASK) | (enc_pfn << PAGE_SHIFT) | _PAGE_ENCODE_BIT;
+
+	*new_pfn = enc_pfn;
+	return __pte(new_val);
+}
+
+void seam_flush_page_with_clwb(void *page_addr)
+{
+	char *addr = (char *)page_addr;
+	int i;
+
+	for (i = 0; i < 64; i++) {
+		clwb(addr);
+		addr += 64;
+	}
+	asm volatile("sfence" ::: "memory");
+}
+
+/*
+ * vm_normal_page_seam - decode encoded PTE, clean up usecount, then delegate
+ * to vm_normal_page() for standard validation.
+ *
+ * @out_pte: if non-NULL, the decoded PTE is written back (unmap path).
+ *           Also controls whether non-encoded CXL pages get usecount cleanup.
+ *           Pass NULL for the COW/readonly path.
+ */
+struct page *vm_normal_page_seam(struct vm_area_struct *vma, unsigned long addr,
+				 pte_t pte, volatile pte_t *out_pte)
+{
+	unsigned long pfn = pte_pfn(pte);
+
+	if ((pte_val(pte) & _PAGE_ENCODE_BIT) && pfn >= end_cxl_pfn) {
+		unsigned long decoded = seam_decode_pfn(pte);
+
+		if (decoded != pfn) {
+			struct page *page = pfn_to_page(decoded);
+			unsigned long mask = ~(PFN_MASK | _PAGE_ENCODE_BIT);
+			unsigned long new_val = (pte_val(pte) & mask) | (decoded << PAGE_SHIFT);
+
+			if (PageKsm(page))
+				atomic_dec(&num_ksm_coded);
+			else
+				atomic_dec(&num_file_coded);
+			pte = __pte(new_val);
+			if (out_pte)
+				*out_pte = pte;
+			reset_page_usecount_v2(page, get_task_cgroup_id(current), decoded);
+		}
+	} else if (out_pte && pfn >= base_pfn && pfn < end_cxl_pfn) {
+		struct page *page = pfn_to_page(pfn);
+
+		if (page->page_cgroup_vector)
+			reset_page_usecount_v2(page, get_task_cgroup_id(current), pfn);
+	}
+
+	return vm_normal_page(vma, addr, pte);
+}
